# ============================================================
# DFIR INTELLIGENCE DASHBOARD — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Only ONE AI engine needs to be configured at a time.
#
# Priority order:  LM Studio  >  OpenAI  >  Anthropic
# ============================================================


# ── AI ENGINE ────────────────────────────────────────────────
#
# Choose ONE of the following three options.
# Comment out the others.
# ─────────────────────────────────────────────────────────────

# OPTION 1 ── LM Studio (local, air-gapped, no data leaves your network)
# Start LM Studio, load a model, start the local server, then copy
# the model identifier shown in the "Local Server" tab.
#
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF


# OPTION 2 ── OpenAI (cloud)
# Get your API key at: https://platform.openai.com/api-keys
# Available models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
#
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o


# OPTION 3 ── Anthropic Claude (cloud)
# Get your API key at: https://console.anthropic.com/
# Available models: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
#
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514


# ── ABUSEIPDB ────────────────────────────────────────────────
# IP reputation checks. Free tier = 1,000 checks/day.
# Get your API key at: https://www.abuseipdb.com/api
#
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here


# ── SERVER ───────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change_this_to_a_random_secret
